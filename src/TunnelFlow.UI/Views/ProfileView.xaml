<UserControl x:Class="TunnelFlow.UI.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TunnelFlow.UI.ViewModels"
             Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,20" MaxWidth="520">

            <!-- Header -->
            <DockPanel Margin="0,0,0,16">
                <TextBlock Text="VLESS Profile" FontSize="18" FontWeight="SemiBold"
                           Foreground="#1E293B" VerticalAlignment="Center"/>
                <TextBlock Text=" (Active)" Foreground="#22C55E" FontWeight="Medium"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>

            <!-- Fields -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Server Address -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Port -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Port" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- User ID -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="User ID (UUID)" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium" TextWrapping="Wrap"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                    <PasswordBox x:Name="UserIdBox"
                                 PasswordChanged="UserIdBox_PasswordChanged"
                                 Padding="8,5" BorderBrush="#CBD5E1"/>
                    <TextBlock Text="e.g. 110263b3-0a2c-4c95-b831-..." IsHitTestVisible="False"
                               Foreground="#94A3B8" FontSize="11" Padding="10,7"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserId}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Flow (e.g. xtls-rprx-vision) -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Flow" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding Flow, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"
                         ToolTip="Leave empty for plain VLESS; use xtls-rprx-vision for REALITY + Vision"/>

                <!-- Network -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Network" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox Grid.Row="5" Grid.Column="1"
                          ItemsSource="{Binding Source={x:Static vm:ProfileViewModel.Networks}}"
                          SelectedItem="{Binding Network}"
                          Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Security -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Security" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox Grid.Row="6" Grid.Column="1"
                          ItemsSource="{Binding Source={x:Static vm:ProfileViewModel.Securities}}"
                          SelectedItem="{Binding Security}"
                          Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- SNI -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="SNI" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="7" Grid.Column="1"
                         Text="{Binding Sni, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Fingerprint -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Fingerprint" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox Grid.Row="8" Grid.Column="1"
                          ItemsSource="{Binding Source={x:Static vm:ProfileViewModel.Fingerprints}}"
                          SelectedItem="{Binding Fingerprint}"
                          Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- REALITY -->
                <TextBlock Grid.Row="9" Grid.Column="0" Text="Reality public key" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium" TextWrapping="Wrap"/>
                <TextBox Grid.Row="9" Grid.Column="1"
                         Text="{Binding RealityPublicKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Reality short ID" VerticalAlignment="Center"
                           Margin="0,0,12,0" Foreground="#475569" FontWeight="Medium" TextWrapping="Wrap"/>
                <TextBox Grid.Row="10" Grid.Column="1"
                         Text="{Binding RealityShortId, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,5" BorderBrush="#CBD5E1"/>
            </Grid>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Save Profile" Command="{Binding SaveCommand}"
                        Padding="16,8" Background="#3B82F6" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
                <Button Content="Set as Active" Command="{Binding ActivateCommand}"
                        Margin="8,0,0,0" Padding="16,8"
                        Background="#22C55E" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <!-- Save status -->
            <TextBlock Text="{Binding SaveStatus}" Margin="0,8,0,0"
                       FontSize="12" Foreground="#64748B"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
