<UserControl x:Class="TunnelFlow.UI.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TunnelFlow.UI.ViewModels"
             Background="#F8FAFC">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,20" MaxWidth="520">

            <!-- Header -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="VLESS Profile" FontSize="18" FontWeight="SemiBold"
                           Foreground="#1E293B"/>
                <TextBlock Text="{Binding ActiveProfileSummary}"
                           Margin="0,6,0,0"
                           Foreground="#22C55E"
                           FontWeight="Medium"/>
            </StackPanel>

            <!-- URL import -->
            <StackPanel Margin="0,0,0,16">
                <TextBlock Text="Import from URL"
                           Margin="0,0,0,4"
                           Foreground="#475569"
                           FontWeight="Medium"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox Width="339"
                             Text="{Binding ImportUrl, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,5"
                             BorderBrush="#CBD5E1"
                             ToolTip="HTTP/HTTPS URL returning one or more supported VLESS profiles, or paste a direct vless:// URI"/>

                    <Button Content="Import URL"
                            Command="{Binding ImportFromUrlCommand}"
                            Margin="8,0,0,0"
                            Padding="11,5"
                            Background="#E0F2FE"
                            Foreground="#0F172A"
                            BorderBrush="#7DD3FC"
                            Cursor="Hand"/>
                </StackPanel>

                <TextBlock Text="{Binding ImportStatus}"
                           Margin="0,6,0,0"
                           Foreground="#475569"
                           FontSize="11"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowImportStatus}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Profile selection -->
            <StackPanel Margin="0,0,0,16">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowProfileSelector}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Selected profile"
                           Margin="0,0,0,4"
                           Foreground="#475569"
                           FontWeight="Medium"/>

                <StackPanel Orientation="Horizontal">
                    <ComboBox Width="196"
                              ItemsSource="{Binding AvailableProfiles}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding SelectedProfile}"
                              IsEnabled="{Binding IsEditingEnabled}"
                              Padding="8,4"
                              BorderBrush="#CBD5E1"/>

                    <Button Content="Set Active"
                            Command="{Binding ActivateCommand}"
                            IsEnabled="{Binding IsEditingEnabled}"
                            Margin="12,0,0,0"
                            Padding="11,5"
                            Background="#22C55E"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Content="Add New"
                            Command="{Binding AddNewCommand}"
                            Margin="8,0,0,0"
                            Padding="11,5"
                            Background="#F1F5F9"
                            Foreground="#475569"
                            BorderBrush="#CBD5E1"
                            Cursor="Hand"/>

                    <Button Content="Delete"
                            Command="{Binding DeleteCommand}"
                            Margin="8,0,0,0"
                            Padding="11,5"
                            Background="#FFF1F2"
                            Foreground="#BE123C"
                            BorderBrush="#FDA4AF"
                            Cursor="Hand"/>
                </StackPanel>

                <Grid Margin="0,8,0,0">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasSubscriptionSource}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="{Binding SubscriptionSourceSummary}"
                                   Foreground="#475569"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SubscriptionSourceUrlDisplay}"
                                   Margin="0,2,0,0"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SubscriptionUpdateSummary}"
                                   Margin="0,2,0,0"
                                   Foreground="#94A3B8"
                                   FontSize="10"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#94A3B8"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SubscriptionMissingFromSource}" Value="True">
                                            <Setter Property="Foreground" Value="#B45309"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="{Binding UpdateSubscriptionButtonText}"
                            Command="{Binding UpdateSubscriptionCommand}"
                            Padding="11,5"
                            Background="#E2E8F0"
                            Foreground="#334155"
                            BorderBrush="#CBD5E1"
                            Cursor="Hand"/>
                </Grid>
            </StackPanel>

            <TextBlock Text="{Binding EditHintText}"
                       Margin="0,0,0,16"
                       Foreground="#64748B"
                       FontSize="11">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowEditHint}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Fields -->
            <Grid IsEnabled="{Binding IsEditingEnabled}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Name -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Server Address -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Server" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding ServerAddress, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Port -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Port" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- User ID -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="User ID (UUID)" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium" TextWrapping="Wrap"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,12">
                    <TextBox Text="{Binding UserId, UpdateSourceTrigger=PropertyChanged}"
                             Padding="8,5" BorderBrush="#CBD5E1"/>
                    <TextBlock Text="e.g. 110263b3-0a2c-4c95-b831-..." IsHitTestVisible="False"
                               Foreground="#94A3B8" FontSize="11" Padding="10,7"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserId}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Flow (e.g. xtls-rprx-vision) -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Flow" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding Flow, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"
                         ToolTip="Leave empty for plain VLESS; use xtls-rprx-vision for REALITY + Vision"/>

                <!-- Network -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Network" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox Grid.Row="5" Grid.Column="1"
                          ItemsSource="{Binding Source={x:Static vm:ProfileViewModel.Networks}}"
                          SelectedItem="{Binding Network}"
                          Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Security -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Security" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox Grid.Row="6" Grid.Column="1"
                          ItemsSource="{Binding Source={x:Static vm:ProfileViewModel.Securities}}"
                          SelectedItem="{Binding Security}"
                          Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- SNI -->
                <TextBlock Grid.Row="7" Grid.Column="0" Text="SNI" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <TextBox Grid.Row="7" Grid.Column="1"
                         Text="{Binding Sni, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- Fingerprint -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Fingerprint" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium"/>
                <ComboBox Grid.Row="8" Grid.Column="1"
                          ItemsSource="{Binding Source={x:Static vm:ProfileViewModel.Fingerprints}}"
                          SelectedItem="{Binding Fingerprint}"
                          Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1"/>

                <!-- REALITY -->
                <TextBlock Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="REALITY requires both public key and short ID."
                           Margin="0,0,0,10"
                           Foreground="#64748B"
                           FontSize="11">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Security}" Value="reality">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="Reality public key" VerticalAlignment="Center"
                           Margin="0,0,12,12" Foreground="#475569" FontWeight="Medium" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Security}" Value="reality">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox Grid.Row="10" Grid.Column="1"
                         Text="{Binding RealityPublicKey, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,12" Padding="8,5" BorderBrush="#CBD5E1">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Security}" Value="reality">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Grid.Row="11" Grid.Column="0" Text="Reality short ID" VerticalAlignment="Center"
                           Margin="0,0,12,0" Foreground="#475569" FontWeight="Medium" TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Security}" Value="reality">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBox Grid.Row="11" Grid.Column="1"
                         Text="{Binding RealityShortId, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,5" BorderBrush="#CBD5E1">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Security}" Value="reality">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </Grid>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" IsEnabled="{Binding IsEditingEnabled}">
                <Button Content="Save Profile" Command="{Binding SaveCommand}"
                        Padding="16,8" Background="#3B82F6" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>

            <!-- Save status -->
            <Border Margin="0,10,0,0"
                    Padding="10,8"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    CornerRadius="8">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SaveStatus}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SaveStatus}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SaveStatus}" Value="Unsaved changes">
                                <Setter Property="Background" Value="#FFFBEB"/>
                                <Setter Property="BorderBrush" Value="#FCD34D"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SaveStatus}" Value="Saved ✓">
                                <Setter Property="Background" Value="#F0FDF4"/>
                                <Setter Property="BorderBrush" Value="#86EFAC"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SaveStatus}" Value="Deleted ✓">
                                <Setter Property="Background" Value="#FFF1F2"/>
                                <Setter Property="BorderBrush" Value="#FDA4AF"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="Save status"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#475569"/>
                    <TextBlock Text="{Binding SaveStatus}"
                               Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#334155"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
