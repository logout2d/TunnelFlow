<UserControl x:Class="TunnelFlow.UI.Views.AppRulesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TunnelFlow.UI.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="#F8FAFC">

    <DockPanel Margin="24,20,24,20">

        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
            <TextBlock Text="App Rules" FontSize="18" FontWeight="SemiBold"
                       Foreground="#1E293B" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Content="＋ Add Application"
                    Command="{Binding AddRuleCommand}"
                    IsEnabled="{Binding IsEditingEnabled}"
                    Padding="12,6" Background="#3B82F6" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </DockPanel>

        <!-- QUIC notice -->
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12"
                   Text="QUIC / HTTP3 is disabled for tunneled apps (by design — forces TCP fallback)."
                   Foreground="#64748B" FontSize="11" FontStyle="Italic"/>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding EditHintText}"
                   Margin="0,0,0,12"
                   Foreground="#64748B"
                   FontSize="11">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowEditHint}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- Column headers -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Application" FontWeight="SemiBold"
                       Foreground="#64748B" FontSize="11"/>
            <TextBlock Grid.Column="2" Text="Mode" FontWeight="SemiBold"
                       Foreground="#64748B" FontSize="11"/>
        </Grid>

        <Separator DockPanel.Dock="Top" Margin="0,0,0,4"/>

        <!-- Rules list -->
        <ListBox ItemsSource="{Binding Rules}"
                 BorderThickness="0" Background="Transparent"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#F1F5F9"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#E2E8F0"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:AppRuleItemViewModel}">
                    <Grid Margin="0,4" MinHeight="36">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                  IsEnabled="{Binding DataContext.IsEditingEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Medium"
                                       Foreground="#1E293B"/>
                            <TextBlock Text="{Binding ExePath}" FontSize="10"
                                       Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <ComboBox Grid.Column="2" SelectedItem="{Binding Mode, Mode=TwoWay}"
                                  IsEnabled="{Binding DataContext.IsEditingEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  VerticalAlignment="Center" Margin="0,0,8,0">
                            <sys:String>Proxy</sys:String>
                            <sys:String>Direct</sys:String>
                            <sys:String>Block</sys:String>
                        </ComboBox>

                        <Button Grid.Column="3" Content="Remove"
                                Command="{Binding DataContext.RemoveRuleCommand,
                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                CommandParameter="{Binding}"
                                IsEnabled="{Binding DataContext.IsEditingEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Padding="6,4" FontSize="11"
                                Background="#FEE2E2" Foreground="#DC2626"
                                BorderThickness="0" Cursor="Hand"
                                VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </DockPanel>
</UserControl>
