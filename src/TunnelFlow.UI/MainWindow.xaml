<Window x:Class="TunnelFlow.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TunnelFlow.UI.Converters"
        Title="TunnelFlow" Height="820" Width="780"
        MinHeight="720" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC">

    <Window.Resources>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>

        <!-- Sidebar button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="#E2E8F0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#475569"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action button style -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Opacity="{TemplateBinding Opacity}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== Sidebar ===== -->
        <Border Grid.Column="0" Background="#1E293B">
            <DockPanel LastChildFill="False">

                <!-- App title + status -->
                <StackPanel DockPanel.Dock="Top" Margin="12,20,12,0">
                    <TextBlock Text="TunnelFlow" FontSize="18" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,12"/>

                    <!-- Row 1: pipe connection state -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                        <TextBlock Text="{Binding ServiceConnectionSummary}"
                                   FontSize="12" Foreground="White"/>
                    </StackPanel>

                    <Button Content="{Binding ServiceActionLabel}"
                            Command="{Binding ManageServiceCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#475569"
                            Foreground="White"
                            Margin="0,8,0,0"/>

                    <Button Content="{Binding UninstallServiceLabel}"
                            Command="{Binding UninstallServiceCommand}"
                            Background="#7F1D1D"
                            Foreground="#FEE2E2"
                            Margin="0,6,0,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActionButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="Background" Value="#7F1D1D"/>
                                <Setter Property="Foreground" Value="#FEE2E2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowUninstallServiceAction}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <TextBlock Text="{Binding ServiceActionStatus}"
                               Margin="0,6,0,0"
                               FontSize="11"
                               Foreground="#CBD5E1"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ShowServiceActionStatus}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Border Background="#0F172A"
                            CornerRadius="10"
                            Margin="0,12,0,0"
                            Padding="10">
                        <StackPanel>
                            <TextBlock Text="Runtime"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mode"
                                           Foreground="#94A3B8" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ModeSummary}"
                                           Foreground="White" FontSize="11" Margin="16,0,0,0"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Engine"
                                           Foreground="#94A3B8" FontSize="11" Margin="0,6,0,0"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="16,6,0,0">
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                             Fill="{Binding SingBoxRunning, Converter={StaticResource BoolToColorConverter}}"/>
                                    <TextBlock Text="{Binding EngineStatusSummary}"
                                               Foreground="White" FontSize="11"/>
                                </StackPanel>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Tunnel"
                                           Foreground="#94A3B8" FontSize="11" Margin="0,6,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="16,6,0,0">
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                             Fill="{Binding TunnelInterfaceUp, Converter={StaticResource BoolToColorConverter}}"/>
                                    <TextBlock Text="{Binding TunnelStatusSummary}"
                                               Foreground="White" FontSize="11"/>
                                </StackPanel>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Profile"
                                           Foreground="#94A3B8" FontSize="11" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ActiveProfileName}"
                                           Foreground="White" FontSize="11" Margin="16,6,0,0"
                                           TextTrimming="CharacterEllipsis"/>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Rules"
                                           Foreground="#94A3B8" FontSize="11" Margin="0,6,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RuleCountsSummary}"
                                           Foreground="White" FontSize="11" Margin="16,6,0,0"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator DockPanel.Dock="Top" Background="#334155" Margin="12,16,12,8"/>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="8,0">
                    <Button Content="📋  App Rules"
                            Command="{Binding NavigateToRulesCommand}"
                            Style="{StaticResource NavButton}"/>
                    <Button Content="⚙  Profile"
                            Command="{Binding NavigateToProfileCommand}"
                            Style="{StaticResource NavButton}"/>
                    <Button Content="📄  Log"
                            Command="{Binding NavigateToLogCommand}"
                            Style="{StaticResource NavButton}"/>
                </StackPanel>

                <!-- Start / Stop at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,0,12,20">
                    <Button Content="▶  Start Tunnel"
                            Command="{Binding StartCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#22C55E" Foreground="White"/>
                    <Button Content="■  Stop Tunnel"
                            Command="{Binding StopCommand}"
                            Style="{StaticResource ActionButton}"
                            Background="#EF4444" Foreground="White"
                            Margin="0,6,0,0"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ===== Content area ===== -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
